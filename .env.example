# =============================================================================
# DocVault Environment Variables — shared by all services
# =============================================================================
# This file is the master .env for the project. dotenv.config() (called from
# each service's main.ts) loads this file when running from the project root.
# Services that need additional vars (DATABASE_URL, S3_*) keep a superset in
# their own services/<name>/.env — those vars are loaded separately via the
# DOTENV_PATH env var or by requiring the service-specific .env explicitly.

# Keycloak (used by all services with JWT auth)
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=docvault
KEYCLOAK_AUDIENCE=docvault-gateway

# PostgreSQL — metadata-service database
DATABASE_URL=postgresql://docvault:docvaultpw@localhost:5432/docvault_metadata?schema=public&client_encoding=UTF8

# MongoDB — audit-service database
MONGODB_URI=mongodb://root:rootpw@localhost:27017/docvault_audit?authSource=admin

# S3 / MinIO — document-service
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadminpw
S3_BUCKET=docvault
S3_FORCE_PATH_STYLE=true

# Download grant secret (shared by metadata-service and document-service)
DOWNLOAD_GRANT_SECRET=docvault-download-grant-secret

# Keycloak admin credentials — used by metadata-service getApprovers()
# to query Keycloak Admin API for users with approver/admin roles.
# Required for SUBMIT notifications to reach approvers.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=adminpw

# Service URLs
METADATA_SERVICE_URL=http://localhost:3001
DOCUMENT_SERVICE_URL=http://localhost:3002
WORKFLOW_SERVICE_URL=http://localhost:3003
AUDIT_SERVICE_URL=http://localhost:3004
NOTIFICATION_SERVICE_URL=http://localhost:3005

# Gateway
GATEWAY_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3006
