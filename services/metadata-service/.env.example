PORT=3001
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=docvault
KEYCLOAK_AUDIENCE=docvault-gateway

DATABASE_URL="postgresql://docvault:docvaultpw@localhost:5432/docvault_metadata?schema=public"
AUDIT_SERVICE_URL=http://localhost:3004
DOWNLOAD_GRANT_SECRET=docvault-download-grant-secret

# ── Notification: approver group lookup ────────────────────────────────────
# Dev/CI: comma-separated user IDs of approvers and admins
# Example: APPROVER_IDS=user-uuid-1,user-uuid-2
APPROVER_IDS=

# Production (Keycloak Admin REST API):
# KEYCLOAK_USERS_BY_GROUP_URL=http://keycloak:8080/auth/admin/realms/docvault
# KEYCLOAK_SERVICE_ACCOUNT_TOKEN=
# KEYCLOAK_APPROVER_GROUP_ID=approvers
# KEYCLOAK_ADMIN_GROUP_ID=admin
